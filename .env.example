# AlgoTrade — Environment Variables
# Copy to .env and fill in values before running
# Never commit .env to version control

# ── Backend Security ───────────────────────────────────────────
SECRET_KEY=algotrade-dev-secret-CHANGE-IN-PROD

# ── Server Ports ──────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=80

# ── Frontend Build (Vite env vars) ───────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ── Data Feed ───────────────────────────────────────────────
# Path to MultiTrade XLS feed on host machine (mounted read-only into container)
MULTITRADE_XLS_PATH=./data/multitrade_feed.xls
