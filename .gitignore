# AlgoTrade .gitignore

# Secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
venv/
.venv/
env/

# Node - ALL locations
node_modules/
**/node_modules/
algo/node_modules/
app/frontend/dist/
app/frontend/.vite/

# Algo junk that should never be committed
algo/package.json
algo/package-lock.json

# Docker
*.tar

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# Data files (sensitive - mount at runtime)
data/*.xls
data/*.xlsx
data/*.csv

# Logs
logs/
*.log

# Coverage
.coverage
htmlcov/
