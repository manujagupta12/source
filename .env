# AlgoTrade — Environment Variables
# ===================================
# Copy this file to .env and fill in your values.
# .env is in .gitignore — it will never be committed.

# ── JWT signing secret ──────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── MultiTrade feed path (optional override) ────────────────
# Default: C:\AlgoTrading\data\multitrade_feed.xls
# MULTITRADE_XLS=C:\AlgoTrading\data\multitrade_feed.xls

# ── Database (production only — not needed for local dev) ───
# DATABASE_URL=postgresql://algotrade:password@localhost:5432/algotrade

# ── Redis (production only — not needed for local dev) ──────
# REDIS_URL=redis://localhost:6379

# NOTE: Delta Exchange has been removed from this project.
# Data sources: NSE API (nse_connector.py) + MultiTrade XLS only.
